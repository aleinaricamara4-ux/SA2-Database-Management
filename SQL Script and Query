SQL Database Script

CREATE DATABASE IF NOT EXISTS stem_historical;
USE stem_historical;

-- All tables are designed in 3NF normalization.
-- Create Countries table
CREATE TABLE countries (
    CountryID INT AUTO_INCREMENT PRIMARY KEY,
    CountryName VARCHAR(100) NOT NULL UNIQUE
);

-- Create Fields table
CREATE TABLE fields (
    FieldID INT AUTO_INCREMENT PRIMARY KEY,
    FieldName VARCHAR(100) NOT NULL UNIQUE
);

-- Create Scientists table
CREATE TABLE scientists (
    ScientistID INT AUTO_INCREMENT PRIMARY KEY,
    FullName VARCHAR(255) NOT NULL,
    BirthYear INT,
    DeathYear INT, -- Can be NULL if the person is alive
    CountryID INT,
    Bio TEXT,
    WorkedForNASA BOOLEAN DEFAULT FALSE,
    WorkedWithEinstein BOOLEAN DEFAULT FALSE,
    FOREIGN KEY (CountryID) REFERENCES countries(CountryID)
);

-- Create Junction table for Scientists and Fields (Many-to-Many)
-- This allows one scientist to have multiple fields (e.g., Physics and Chemistry)

CREATE TABLE scientist_fields (
    ScientistID INT,
    FieldID INT,
    PRIMARY KEY (ScientistID, FieldID),
    FOREIGN KEY (ScientistID) REFERENCES scientists(ScientistID),
    FOREIGN KEY (FieldID) REFERENCES fields(FieldID)
);

-- Create Rooms table (types: lecture room, event room)
CREATE TABLE rooms (
    RoomID INT AUTO_INCREMENT PRIMARY KEY,
    RoomName VARCHAR(100) NOT NULL,
    RoomType ENUM('Lecture room', 'Event room') NOT NULL
);

-- Create Events table (requirement: each event needs a speaker)
CREATE TABLE events (
    EventID INT AUTO_INCREMENT PRIMARY KEY,
    EventName VARCHAR(255) NOT NULL,
    SpeakerName VARCHAR(255) NOT NULL,
    RoomID INT,
    RequiresTicket BOOLEAN DEFAULT FALSE,
    FOREIGN KEY (RoomID) REFERENCES rooms(RoomID)
);

-- Create Event Topics junction (requirement: events can have multiple topics)
CREATE TABLE event_topics (
    EventID INT,
    ScientistID INT,
    PRIMARY KEY (EventID, ScientistID),
    FOREIGN KEY (EventID) REFERENCES events(EventID),
    FOREIGN KEY (ScientistID) REFERENCES scientists(ScientistID)
);



