SQL QUERIES

-- Q1. List all historical figures that were born in France
SELECT FullName FROM scientists s 
JOIN countries c ON s.CountryID = c.CountryID 
WHERE c.CountryName = 'France';

-- Q2. List all historical figures that contributed to Computing
SELECT s.FullName FROM scientists s 
JOIN scientist_fields sf ON s.ScientistID = sf.ScientistID 
JOIN fields f ON sf.FieldID = f.FieldID 
WHERE f.FieldName = 'Computing';

-- Q3. List all historical figures that contributed to more than 1 field
SELECT s.FullName FROM scientists s 
JOIN scientist_fields sf ON s.ScientistID = sf.ScientistID 
GROUP BY s.ScientistID 
HAVING COUNT(sf.FieldID) > 1;

-- Q4. Mary Jackson’s death is incorrectly listed. Update this date to 2005
UPDATE scientists SET DeathYear = 2005 WHERE FullName = 'Mary Jackson';

-- Q5. List all historical figures who died before they were 40
SELECT FullName, (DeathYear - BirthYear) AS AgeAtDeath FROM scientists 
WHERE (DeathYear - BirthYear) < 40;

-- Q6. Which countries have the most historical figures listed
SELECT c.CountryName, COUNT(s.ScientistID) AS TotalCount 
FROM countries c 
JOIN scientists s ON c.CountryID = s.CountryID 
GROUP BY c.CountryName 
ORDER BY TotalCount DESC;

-- Q7. Are any historical figures still alive? If so who
-- (Based on data where DeathYear is NULL)
SELECT FullName FROM scientists WHERE DeathYear IS NULL;

-- Q8. Which historical figures worked for NASA
SELECT FullName FROM scientists WHERE WorkedForNASA = TRUE;


-- Q9. Which historical figures worked with Einstein?
SELECT FullName FROM scientists WHERE WorkedWithEinstein = TRUE;

-- Q10. Which countries have the most fields of research contributions
SELECT c.CountryName, COUNT(DISTINCT sf.FieldID) AS UniqueFields 
FROM countries c 
JOIN scientists s ON c.CountryID = s.CountryID 
JOIN scientist_fields sf ON s.ScientistID = sf.ScientistID 
GROUP BY c.CountryName 
ORDER BY UniqueFields DESC;
